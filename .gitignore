*.suo
*.user
*.userosscache
*.sln.docstates
*.suo
*.suo.tmp
*.cache
*.db
*.opendb
*.VC.db
.vs/
AppPackages/
BundleArtifacts/
PackageArtifacts/
_ReSharper*/
*.[Cc]odot
*.dyn
*.tmp
